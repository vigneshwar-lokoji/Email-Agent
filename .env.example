# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ─── LLM Backend ─────────────────────────────────────────────────────────────
# Option A: Vertex AI (recommended for production)
#   Set USE_VERTEX_AI=True in ai_nodes.py
#   Requires: service_account.json with Vertex AI User role
VERTEX_AI_LOCATION=us-central1

# Option B: Gemini API key (quick start, no GCP needed)
#   Set USE_VERTEX_AI=False in ai_nodes.py
GEMINI_API_KEY=your-gemini-api-key

# ─── User Settings ───────────────────────────────────────────────────────────
USER_TIMEZONE=America/New_York
USER_FIRST_NAME=YourName
